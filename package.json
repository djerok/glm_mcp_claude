    "hooks/",
    "docs/",
    "assets/",
    "install.mjs",
    "uninstall.mjs",
    "glm-code.mjs",
    ".mcp.json.example",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude-code",
    "mcp",
    "model-context-protocol",
    "glm",
    "zhipu",
    "z.ai",
    "subagent",
    "ai-agents",
    "anthropic",
    "llm",
    "cost-optimization"
  ],
